{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git init:*)",
      "Bash(git submodule add:*)",
      "Bash(git -c protocol.file.allow=always submodule add:*)",
      "Bash(dotnet:*)",
      "Bash(dotnet --list-sdks:*)",
      "Bash(python3:*)",
      "Bash(bash ~/.claude/hooks/scripts/apply-session-rename.sh:*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/pre_impl_gate.py",
            "timeout": 15
          }
        ]
      },
      {
        "matcher": "AskUserQuestion|EnterPlanMode|ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"hookSpecificOutput\":{\"hookEventName\":\"PreToolUse\",\"permissionDecision\":\"deny\",\"permissionDecisionReason\":\"Blocked by user config. AskUserQuestion and the plan-mode tools (EnterPlanMode/ExitPlanMode) interrupt the session silently, and Ben cannot tell what happened when many agents run in parallel. Do NOT retry this tool. To get his attention or a decision, invoke the /notify skill with a clear, specific message, then continue with a best-judgment default or stop. Keep making forward progress where possible.\"}}'",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/post_impl_gate.py",
            "timeout": 15
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/auto-rename-session.sh"
          },
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/response-deferral-phrase-gate.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/loop_spin_gate.py",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "python3 ~/.claude/hooks/subagent_nudge.py",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash ~/.claude/statusline-command.sh"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true
  },
  "effortLevel": "xhigh",
  "voice": {
    "enabled": true,
    "mode": "hold"
  },
  "skipDangerousModePermissionPrompt": true,
  "skipAutoPermissionPrompt": true,
  "theme": "dark",
  "verbose": true,
  "teammateMode": "tmux",
  "remoteControlAtStartup": true,
  "voiceEnabled": true
}
